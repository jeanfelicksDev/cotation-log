// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Quotation {
  id          String   @id @default(cuid())
  reference   String   @unique
  clientName  String
  direction   String   // "import" or "export"
  status      String   @default("Draft") // "Draft", "Sent", "Accepted", "Rejected"
  
  // New logistical parameters
  origin      String?
  destination String?
  commodity   String?
  mode        String?    // "sea", "air", "road"
  frequency   String?    // ex: "Weekly"
  transitTime String?    // ex: "15 days"
  via         String?
  carrier     String?    // ex: "Maersk"
  
  // Goods details
  nbColis     Int?
  grossWeight Float?
  volume      Float?
  commodityValue Float?
  temperature String?
  isDangerous Boolean?   @default(false)
  
  incoterm    String?
  
  totalBase   Float
  totalFinal  Float
  margin      Float
  reason      String?
  comments    String?
  clientResponseDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  items       QuotationItem[]
  containers  QuotationContainer[]
}

model QuotationContainer {
  id          String    @id @default(cuid())
  type        String    // ex: "20GP", "40HC"
  quantity    Int       @default(1)
  
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model QuotationItem {
  id          String    @id @default(cuid())
  description String
  amount      Float
  type        String    // "fret", "fret_air", "thc", "doc", "other"
  currency    String    @default("EUR")
  
  // Fret Forwarding options
  isForwarding Boolean  @default(false)
  buyAmount    Float?
  marginRate   Float?
  
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model Parameter {
  id        String   @id @default(cuid())
  category  String   // "destination", "origin", "container", "commodity", "status"
  label     String
  value     String
  createdAt DateTime @default(now())
  reasons   ParameterReason[]
}

model ParameterReason {
  id          String    @id @default(cuid())
  label       String
  parameterId String
  parameter   Parameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)
}

model Tariff {
  id          String   @id @default(cuid())
  zone        String
  description String
  amount      Float
  currency    String   @default("EUR")
  type        String
}

model FreightRate {
  id            String   @id @default(cuid())
  carrier       String   // Compagnie maritime (ex: CMA CGM)
  origin        String   // Port de départ
  destination   String   // Port d'arrivée
  containerType String   // Type de conteneur (ex: 20GP, 40HC)
  commodity     String   // Type de marchandise
  amount        Float    // Tarif d'achat
  currency      String   @default("EUR")
  validFrom     DateTime // Début validité
  validTo       DateTime // Fin validité
  createdAt     DateTime @default(now())
}

model CompanyProfile {
  id            String   @id @default("singleton")
  corporateName String   @default("Ma Société")
  address       String?
  phone         String?
  email         String?
  logo          String?  @db.Text
  updatedAt     DateTime @updatedAt
}

// ─── Licence & Accès ───────────────────────────────────────────────

model License {
  id           String    @id @default(cuid())
  key          String    @unique
  companyName  String
  contactEmail String
  maxUsers     Int       @default(10)
  expiresAt    DateTime?
  activatedAt  DateTime?
  isActive     Boolean   @default(false)
  notes        String?
  createdAt    DateTime  @default(now())

  organization Organization?
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  licenseId String  @unique
  license   License @relation(fields: [licenseId], references: [id])

  users       User[]
  inviteTokens InviteToken[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())

  orgId String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model InviteToken {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  orgId String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

enum Role {
  SUPER_ADMIN // Vous (générateur de licences)
  ADMIN       // Admin de l'entreprise cliente
  EMPLOYEE    // Collaborateur
}
